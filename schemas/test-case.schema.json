{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Test Case",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "title", "goal", "tags", "apps"],
  "properties": {
    "id": {"type": "string", "pattern": "^case-[a-z0-9-]+$"},
    "title": {"type": "string", "minLength": 1},
    "goal": {"type": "string", "minLength": 1},
    "tags": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "apps": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "minItems": 1,
      "uniqueItems": true
    },
    "priority": {
      "type": "string",
      "enum": ["low", "medium", "high"],
      "default": "medium"
    },
    "owner": {"type": "string"},
    "enabled": {"type": "boolean", "default": true}
  }
}
