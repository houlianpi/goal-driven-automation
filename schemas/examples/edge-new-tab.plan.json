{
  "plan_id": "plan-edge-new-tab",
  "version": "1.0.0",
  "goal": "Test Edge new tab creation",
  "app": "Microsoft Edge",
  "created_at": "2026-04-09T14:00:00+08:00",
  "steps": [
    {
      "step_id": "step-1-launch",
      "action": "launch",
      "params": {"app": "Microsoft Edge"},
