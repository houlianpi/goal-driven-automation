{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Plan IR Schema",
  "description": "Intermediate Representation for execution plans",
  "version": "1.0.0",
  "type": "object",
  "required": ["plan_id", "version", "goal", "app", "steps"],
  "properties": {
    "plan_id": {
      "type": "string",
      "description": "Unique plan identifier",
      "pattern": "^plan-[a-z0-9-]+$"
    },
    "version": {
      "type": "string",
      "description": "Schema version",
      "const": "1.0.0"
    },
    "goal": {
      "type": "string",
      "description": "Original goal in natural language"
    },
    "app": {
      "type": "string",
      "description": "Target application bundle ID or name"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "goal_id": {"type": "string"},
        "goal_type": {"type": "string"},
        "author": {"type": "string"},
        "tags": {"type": "array", "items": {"type": "string"}},
        "timeout_ms": {"type": "integer", "default": 60000}
      }
    },
    "preconditions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["check", "expected"],
        "properties": {
          "check": {"type": "string"},
          "expected": {"type": "string"},
          "on_fail": {"type": "string", "enum": ["abort", "warn"]}
        }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/definitions/step"}
    }
  },
  "definitions": {
    "step": {
      "type": "object",
      "required": ["step_id", "action"],
      "properties": {
        "step_id": {
          "type": "string",
          "description": "Unique step identifier within plan"
        },
        "action": {
          "type": "string",
          "enum": ["launch", "shortcut", "type", "click", "wait", "assert", "capture"]
        },
        "params": {
          "type": "object"
        },
        "expected_signal": {
          "type": "string",
          "description": "What indicates success"
        },
        "retry_policy": {"$ref": "#/definitions/retry_policy"},
        "on_fail": {
          "type": "string",
          "enum": ["abort", "skip", "continue", "retry", "replan", "human_review"],
          "default": "abort"
        },
        "review_required": {
          "type": "boolean",
          "default": false
        },
        "evidence": {
          "type": "object",
          "properties": {
            "screenshot_before": {"type": "boolean"},
            "screenshot_after": {"type": "boolean"},
            "capture_ui_tree": {"type": "boolean"}
          }
        },
        "metadata": {
          "type": "object",
          "properties": {
            "context_confidence": {"type": "string", "enum": ["low", "medium", "high"]}
          },
          "additionalProperties": true
        }
      },
      "allOf": [
        {
          "if": {"properties": {"action": {"const": "launch"}}},
          "then": {"required": ["params"], "properties": {"params": {"$ref": "#/definitions/launch_params"}}}
        },
        {
          "if": {"properties": {"action": {"const": "shortcut"}}},
          "then": {"required": ["params"], "properties": {"params": {"$ref": "#/definitions/shortcut_params"}}}
        },
        {
          "if": {"properties": {"action": {"const": "type"}}},
          "then": {"required": ["params"], "properties": {"params": {"$ref": "#/definitions/type_params"}}}
        },
        {
          "if": {"properties": {"action": {"const": "click"}}},
          "then": {"required": ["params"], "properties": {"params": {"$ref": "#/definitions/click_params"}}}
        },
        {
          "if": {"properties": {"action": {"const": "wait"}}},
          "then": {"required": ["params"], "properties": {"params": {"$ref": "#/definitions/wait_params"}}}
        },
        {
          "if": {"properties": {"action": {"const": "assert"}}},
          "then": {"required": ["params"], "properties": {"params": {"$ref": "#/definitions/assert_params"}}}
        },
        {
          "if": {"properties": {"action": {"const": "capture"}}},
          "then": {"required": ["params"], "properties": {"params": {"$ref": "#/definitions/capture_params"}}}
        }
      ]
    },
    "launch_params": {
      "type": "object",
      "required": ["app"],
      "properties": {
        "app": {"type": "string", "description": "App name or bundle ID"}
      },
      "additionalProperties": false
    },
    "shortcut_params": {
      "type": "object",
      "required": ["keys"],
      "properties": {
        "keys": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Key combination, e.g. [\"command\", \"t\"]"
        }
      },
      "additionalProperties": false
    },
    "type_params": {
      "type": "object",
      "required": ["text"],
      "properties": {
        "text": {"type": "string"},
        "delay_ms": {"type": "integer", "default": 50},
        "app": {"type": "string"},
        "requires_focused_target": {"type": "boolean"},
        "input_target": {"type": "string"}
      },
      "additionalProperties": false
    },
    "click_params": {
      "type": "object",
      "properties": {
        "selector": {"type": "string", "description": "Accessibility selector"},
        "app": {"type": "string"},
        "locator_text": {"type": "string"},
        "locator_role": {"type": "string"},
        "x": {"type": "number"},
        "y": {"type": "number"},
        "button": {"type": "string", "enum": ["left", "right"], "default": "left"}
      },
      "anyOf": [
        {"required": ["selector"]},
        {"required": ["x", "y"]}
      ],
      "additionalProperties": false
    },
    "wait_params": {
      "type": "object",
      "properties": {
        "seconds": {"type": "number"},
        "condition": {"type": "string"},
        "timeout_ms": {"type": "integer", "default": 10000}
      },
      "anyOf": [
        {"required": ["seconds"]},
        {"required": ["condition"]}
      ],
      "additionalProperties": false
    },
    "assert_params": {
      "type": "object",
      "required": ["condition"],
      "properties": {
        "condition": {"type": "string"},
        "message": {"type": "string"},
        "locator": {"type": "string"},
        "strategy": {"type": "string"}
      },
      "additionalProperties": false
    },
    "capture_params": {
      "type": "object",
      "properties": {
        "type": {"type": "string", "enum": ["screenshot", "ui_tree", "both"]},
        "selector": {"type": "string"}
      },
      "additionalProperties": false
    },
    "retry_policy": {
      "type": "object",
      "properties": {
        "max_attempts": {"type": "integer", "default": 3, "minimum": 1},
        "backoff": {"type": "string", "enum": ["none", "linear", "exponential"], "default": "linear"},
        "delay_ms": {"type": "integer", "default": 1000}
      }
    }
  }
}
